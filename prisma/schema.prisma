generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                        String    @id @default(cuid())
  name                      String
  email                     String    @unique
  password                  String
  role                      Role      @default(STUDENT)
  college                   String?
  phone                     String?
  isVerified                Boolean   @default(false)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  emailVerified             Boolean   @default(false)
  verifyToken               String?
  resetExpiresAt            DateTime?
  resetToken                String?
  profileImageUrl           String?
  isSuspended               Boolean   @default(false)
  strikeCount               Int       @default(0)
  collegeIdImageUrl         String?
  collegeIdNumber           String?
  studentVerificationStatus String    @default("NOT_SUBMITTED")
  studentVerified           Boolean   @default(false)
  selfieImageUrl            String?
  buyerDeals                Deal[]    @relation("BuyerDeals")
  sellerDeals               Deal[]    @relation("SellerDeals")
  products                  Product[]
}

model College {
  id         String    @id @default(cuid())
  name       String    @unique
  city       String
  state      String
  isApproved Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime? @updatedAt
}

model CollegeRequest {
  id          String    @id @default(cuid())
  collegeName String
  userEmail   String
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt
}

model Product {
  id          String        @id @default(cuid())
  title       String
  description String
  price       Int
  category    String
  condition   String
  status      ProductStatus @default(AVAILABLE)
  sellerId    String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  imageUrls   String[]
  buyerId     String?
  finalPrice  Int?
  invoiceId   String?
  soldAt      DateTime?
  deals       Deal[]

  seller User @relation(fields: [sellerId], references: [id])
}

model Order {
  id                String    @id @default(cuid())
  productId         String
  buyerId           String
  sellerId          String
  amount            Int
  razorpayOrderId   String?
  razorpayPaymentId String?
  paymentStatus     String    @default("PENDING")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  cancelReason      String?
  cancelledAt       DateTime?
  cancelledBy       String?
}

model Conversation {
  id        String   @id @default(cuid())
  buyerId   String
  sellerId  String
  productId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  text           String
  createdAt      DateTime     @default(now())
  readByBuyer    Boolean      @default(false)
  readBySeller   Boolean      @default(false)
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

model SupportTicket {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Report {
  id         String   @id @default(cuid())
  reporterId String?
  targetType String
  targetId   String
  reason     String
  details    String?
  status     String   @default("OPEN")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  adminEmail String
  action     String
  targetType String?
  targetId   String?
  details    String?
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

model AdBanner {
  id          String   @id @default(cuid())
  title       String
  description String
  buttonText  String?
  buttonLink  String?
  badge       String?
  emoji       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  imageUrl    String?
}

model Deal {
  id String @id @default(cuid())

  productId String
  product   Product @relation(fields: [productId], references: [id])

  buyerId String
  buyer   User   @relation("BuyerDeals", fields: [buyerId], references: [id])

  sellerId String
  seller   User   @relation("SellerDeals", fields: [sellerId], references: [id])

  originalPrice Int
  finalPrice    Int

  invoiceId String @unique

  paymentMethod String

  status DealStatus @default(PENDING)

  sellerConfirmed Boolean @default(true)
  buyerConfirmed  Boolean @default(false)

  completedAt DateTime?
  confirmedAt DateTime?

  createdAt DateTime @default(now())
}

enum Role {
  STUDENT
  ADMIN
}

enum ProductStatus {
  AVAILABLE
  SOLD
  REMOVED
}

enum DealStatus {
  PENDING
  COMPLETED
  CANCELLED
  EXPIRED
}
